---
import BaseLayout from './BaseLayout.astro';
import { docsNav } from '../config/docs-nav';
import type { NavSection } from '../config/docs-nav';

interface Props {
  title: string;
  currentSlug: string;
}

const { title, currentSlug } = Astro.props;
---

<BaseLayout title={`${title} — HerdOS Docs`} description={`HerdOS documentation: ${title}`}>
  <!-- Mobile sidebar toggle in header -->
  <button
    slot="header-start"
    id="sidebar-toggle"
    class="md:hidden text-white/70 hover:text-white transition-colors"
    aria-label="Toggle navigation"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div class="max-w-6xl mx-auto px-4 py-10 flex gap-10">
    <!-- Mobile sidebar overlay -->
    <div id="sidebar-overlay" class="md:hidden fixed inset-0 top-16 bg-black/50 z-40 hidden"></div>

    <!-- Sidebar -->
    <nav id="sidebar" class="hidden md:block w-56 flex-shrink-0 max-md:fixed max-md:top-16 max-md:bottom-0 max-md:left-0 max-md:z-50 max-md:w-72 max-md:bg-navy max-md:p-6 max-md:overflow-y-auto max-md:shadow-2xl">
      <div class="sticky top-24 space-y-6 max-md:static">
        {docsNav.map((section: NavSection) => (
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-white/40 mb-2">{section.label}</h4>
            <ul class="space-y-1">
              {section.items.map((item) => (
                <li>
                  <a
                    href={`/docs/${item.slug}`}
                    class:list={[
                      'block px-3 py-1.5 rounded text-sm transition-colors',
                      currentSlug === item.slug
                        ? 'bg-orange/10 text-orange font-medium'
                        : 'text-white/60 hover:text-white hover:bg-white/5',
                    ]}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>
    <!-- Content -->
    <article class="flex-1 min-w-0 prose prose-invert prose-orange max-w-none
      prose-headings:text-white prose-headings:font-bold
      prose-h1:text-3xl prose-h1:mb-6
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-white/70 prose-p:leading-relaxed
      prose-a:text-orange hover:prose-a:text-orange-dark
      prose-strong:text-white
      prose-code:text-orange prose-code:bg-navy-light prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-navy-light prose-pre:border prose-pre:border-white/10
      prose-li:text-white/70
      prose-table:text-white/70
      prose-th:text-white prose-th:font-semibold
      prose-td:border-white/10 prose-th:border-white/10">
      <slot />
    </article>
  </div>
</BaseLayout>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const overlay = document.getElementById('sidebar-overlay');
  const sidebar = document.getElementById('sidebar');

  function openSidebar() {
    sidebar?.classList.remove('hidden');
    sidebar?.classList.add('block');
    overlay?.classList.remove('hidden');
  }

  function closeSidebar() {
    sidebar?.classList.remove('block');
    sidebar?.classList.add('hidden');
    overlay?.classList.add('hidden');
  }

  function toggleSidebar() {
    if (sidebar?.classList.contains('hidden')) {
      openSidebar();
    } else {
      closeSidebar();
    }
  }

  toggle?.addEventListener('click', toggleSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>

<script>
  async function initMermaid() {
    const codeBlocks = document.querySelectorAll('pre[data-language="mermaid"] > code');
    if (codeBlocks.length === 0) return;

    // Preserve original <pre> elements for fallback on error
    const originals = new Map<Element, { pre: Element; parent: Node; next: Node | null }>();
    codeBlocks.forEach((codeEl) => {
      const pre = codeEl.parentElement;
      if (!pre || !pre.parentNode) return;
      originals.set(pre, { pre: pre.cloneNode(true) as Element, parent: pre.parentNode, next: pre.nextSibling });
    });

    // Insert loading spinners next to each hidden pre block
    const spinners: HTMLElement[] = [];
    codeBlocks.forEach((codeEl) => {
      const pre = codeEl.parentElement;
      if (!pre || !pre.parentNode) return;
      const spinner = document.createElement('div');
      spinner.className = 'mermaid-loading';
      pre.parentNode.insertBefore(spinner, pre.nextSibling);
      spinners.push(spinner);
    });

    try {
      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11.4.1/dist/mermaid.esm.min.mjs');

      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        flowchart: {
          padding: 30,
          wrappingWidth: 200,
          useMaxWidth: true,
        },
      });

      codeBlocks.forEach((codeEl) => {
        const pre = codeEl.parentElement;
        if (!pre) return;
        const div = document.createElement('div');
        div.className = 'mermaid';
        const raw = codeEl.textContent || '';
        // Escape '1. ', '2. ' etc. so Mermaid's markdown parser doesn't treat them as list items
        div.textContent = raw.replace(/(\d+)\. /g, '$1\\. ');
        pre.replaceWith(div);
      });

      await mermaid.run();
      spinners.forEach((s) => s.remove());
    } catch (e) {
      console.error('Mermaid rendering failed, restoring original code blocks:', e);
      spinners.forEach((s) => s.remove());
      // Restore original <pre> elements so users can still see the diagram source
      document.querySelectorAll('.mermaid').forEach((div) => div.remove());
      originals.forEach(({ pre, parent, next }) => {
        parent.insertBefore(pre, next);
        (pre as HTMLElement).removeAttribute('data-language');
        (pre as HTMLElement).style.visibility = 'visible';
        (pre as HTMLElement).style.height = 'auto';
        (pre as HTMLElement).style.overflow = 'visible';
      });
    }
  }

  initMermaid();
</script>

<style is:global>
  pre[data-language="mermaid"] {
    visibility: hidden;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .mermaid-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
    margin: 1.5rem 0;
  }

  .mermaid-loading::after {
    content: '';
    width: 2rem;
    height: 2rem;
    border: 3px solid #1e2d3d;
    border-top-color: #ee7926;
    border-radius: 50%;
    animation: mermaid-spin 0.8s linear infinite;
  }

  @keyframes mermaid-spin {
    to { transform: rotate(360deg); }
  }

  .mermaid {
    background: transparent;
    text-align: center;
    margin: 1.5rem 0;
  }
  .mermaid svg {
    max-width: 100%;
    height: auto;
  }
  .mermaid .nodeLabel,
  .mermaid .cluster-label .nodeLabel {
    overflow: visible !important;
    white-space: normal;
  }
  .mermaid foreignObject {
    overflow: visible;
  }
</style>
