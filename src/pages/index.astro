---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import HerdDemo from '../components/HerdDemo.jsx';
---

<BaseLayout
  title="HerdOS — GitHub-native AI agent orchestration"
  description="HerdOS orchestrates AI coding agents through GitHub. One command. Parallel agents. One reviewed PR."
>
  <!-- Hero Section -->
  <section class="py-24 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <div class="flex justify-center mb-8">
        <img src="/logo.svg" alt="HerdOS" class="h-72" />
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold mb-6 leading-tight">
        One command. Parallel agents.<br />One reviewed PR.
      </h1>
      <p class="text-xl sm:text-2xl text-white/70 mb-10 max-w-2xl mx-auto leading-relaxed">
        HerdOS orchestrates AI coding agents through GitHub. Describe a feature, walk away, and come back to a reviewed pull request ready to merge.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/docs/getting-started"
          class="inline-block bg-orange hover:bg-orange-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          Get Started
        </a>
        <a
          href="https://github.com/herd-os/herd"
          class="inline-block border border-white/30 hover:border-white/60 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Demo Section -->
  <section class="pb-12 px-4">
    <div class="flex justify-center">
      <HerdDemo client:visible />
    </div>
  </section>

  <!-- Pain Section -->
  <section class="py-20 px-4 bg-navy-light/30">
    <div class="max-w-3xl mx-auto text-center space-y-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-4 text-white/80">You're not building. You're babysitting.</h2>
      <p class="text-lg text-white/70 leading-relaxed">
        You open four terminal tabs. You assign each agent a task. You check back every ten minutes to see if anyone's stuck. You're not building — you're babysitting.
      </p>
      <p class="text-lg text-white/70 leading-relaxed">
        Two agents touch the same file. You get a merge conflict. Now you're the human merge resolution layer, untangling AI-generated code you didn't write.
      </p>
      <p class="text-lg text-white/70 leading-relaxed">
        An agent stalls silently. No error, no notification. You discover it an hour later, kill it, and start over. That's an hour of compute and context — gone.
      </p>
      <p class="text-xl text-white font-bold mt-8">
        Coordinating AI agents shouldn't be your full-time job.
      </p>
    </div>
  </section>

  <!-- What the system handles for you -->
  <section class="py-20 px-4 bg-navy-light/30">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">What the system handles for you</h2>
      <p class="text-white/60 text-center mb-12">You describe a feature. The system handles everything else.</p>
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <span class="text-orange mt-2 text-lg leading-none">•</span>
          <div class="bg-navy-light rounded-xl p-4 flex-1 border border-white/5">
            <p class="text-white/70 text-sm">Workers execute tasks in parallel on self-hosted runners, each on an isolated branch — no contention, no coordination overhead</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-orange mt-2 text-lg leading-none">•</span>
          <div class="bg-navy-light rounded-xl p-4 flex-1 border border-white/5">
            <p class="text-white/70 text-sm">The integrator consolidates branches and auto-resolves merge conflicts between parallel workers</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-orange mt-2 text-lg leading-none">•</span>
          <div class="bg-navy-light rounded-xl p-4 flex-1 border border-white/5">
            <p class="text-white/70 text-sm">DAG-based scheduling dispatches the next tier of tasks automatically as dependencies complete</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-orange mt-2 text-lg leading-none">•</span>
          <div class="bg-navy-light rounded-xl p-4 flex-1 border border-white/5">
            <p class="text-white/70 text-sm">The monitor detects crashed or stalled workers and redispatches them with exponential backoff</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-orange mt-2 text-lg leading-none">•</span>
          <div class="bg-navy-light rounded-xl p-4 flex-1 border border-white/5">
            <p class="text-white/70 text-sm">An agent reviews the consolidated PR for bugs and security issues — you come back to a single PR ready to merge</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-16">Built for the AI-native workflow</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:zap" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">Parallel Execution</h3>
          <p class="text-white/60 text-sm leading-relaxed">Multiple agents work simultaneously on isolated branches. No contention, no waiting — just throughput.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="simple-icons:github" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">GitHub-Native</h3>
          <p class="text-white/60 text-sm leading-relaxed">Built on Issues, Actions, and PRs. No custom infrastructure, no databases, no daemons to run.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:refresh-cw" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">Self-Healing</h3>
          <p class="text-white/60 text-sm leading-relaxed">Crashed workers are detected and redispatched automatically with exponential backoff. No silent failures.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:git-merge" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">Conflict Resolution</h3>
          <p class="text-white/60 text-sm leading-relaxed">When parallel agents touch overlapping code, merge conflicts are detected and resolved without human intervention.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:bot" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">Agent Review</h3>
          <p class="text-white/60 text-sm leading-relaxed">An AI reviewer checks the consolidated PR for bugs, security issues, and style — before you ever see it.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:plug" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">Agent-Agnostic</h3>
          <p class="text-white/60 text-sm leading-relaxed">Claude Code is the first-class supported agent today. The architecture supports any agent that can read a task and produce code — Codex, Gemini CLI, and others are on the roadmap.</p>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5 hover:border-orange/30 transition-colors">
          <div class="mb-4"><Icon name="lucide:shield-check" class="size-8 text-orange" /></div>
          <h3 class="text-lg font-bold mb-2">You stay in control</h3>
          <p class="text-white/60 text-sm leading-relaxed">Workers run autonomously, but nothing merges without your approval. You review the PR, you decide what ships.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="py-20 px-4 bg-navy-light/30">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-12">Who this is for</h2>
      <div class="space-y-4 text-lg text-white/70 leading-relaxed">
        <div class="flex items-start gap-3">
          <span class="text-orange mt-1">•</span>
          <p>Solo developers using AI coding agents who want to parallelize work without managing multiple terminals</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-orange mt-1">•</span>
          <p>Small teams coordinating agents across a shared codebase</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-orange mt-1">•</span>
          <p>Anyone already on GitHub who wants agent orchestration without new infrastructure to deploy or maintain</p>
        </div>
      </div>
      <p class="text-white/40 text-sm mt-8 text-center">Not a fit if: HerdOS requires self-hosted GitHub Actions runners. If you're not on GitHub or can't run self-hosted runners, it's not the right tool yet.</p>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-16">Built for real features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-navy-light rounded-xl p-6 border border-white/5">
          <div class="bg-navy rounded-lg p-4">
            <code class="text-orange text-sm font-mono">herd plan "Add user authentication"</code>
          </div>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5">
          <div class="bg-navy rounded-lg p-4">
            <code class="text-orange text-sm font-mono">herd plan "Migrate from REST to GraphQL"</code>
          </div>
        </div>
        <div class="bg-navy-light rounded-xl p-6 border border-white/5">
          <div class="bg-navy rounded-lg p-4">
            <code class="text-orange text-sm font-mono">herd plan "Upgrade React 17 to 19"</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gastown Heritage Section -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center border-t border-white/10 pt-16">
      <p class="text-white/60 text-sm leading-relaxed italic">
        Inspired by <a href="https://github.com/steveyegge/gastown" class="text-white/80 underline hover:text-white">Gastown</a>, Steve Yegge's multi-agent orchestration system. HerdOS carries forward its proven ideas — role decomposition, batch-based delivery, nondeterministic idempotence — but replaces tmux sessions, Dolt databases, and battery-draining polling daemons with GitHub Issues, Actions, and event-driven workflows. Zero infrastructure. Zero local compute.
      </p>
    </div>
  </section>

  <!-- Quick Start Section -->
  <section class="py-20 px-4 bg-navy-light/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">Quick Start</h2>
      <p class="text-white/60 text-center mb-10">Up and running in minutes</p>
      <div class="max-w-2xl mx-auto bg-navy-light rounded-xl p-6 font-mono text-sm leading-loose border border-white/10">
        <div><span class="text-white/40">$</span> <span class="text-white">brew install herd-os/tap/herd</span></div>
        <div><span class="text-white/40">$</span> <span class="text-white">cd your-repo</span></div>
        <div><span class="text-white/40">$</span> <span class="text-white">herd init</span></div>
        <div><span class="text-white/40">$</span> <span class="text-white">herd plan <span class="text-orange">"Add user authentication"</span></span></div>
        <div><span class="text-white/40">$</span> <span class="text-white">herd status --watch</span> <span class="text-white/40"># watch workers execute in real-time</span></div>
      </div>
      <div class="max-w-2xl mx-auto mt-6 bg-orange/10 border border-orange/30 rounded-xl p-4 text-sm text-white/70">
        <p><span class="text-orange font-semibold">Note:</span> HerdOS runs workers on self-hosted GitHub Actions runners. You'll need at least one runner set up before dispatching. <a href="/docs/runners" class="text-orange underline hover:text-orange-dark">See the runner setup guide →</a></p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Ready to herd your agents?</h2>
      <p class="text-white/60 text-lg mb-10">Ship features faster with parallel AI agents — no babysitting required</p>
      <a
        href="https://github.com/herd-os/herd"
        class="inline-block bg-orange hover:bg-orange-dark text-white font-semibold px-10 py-4 rounded-lg transition-colors text-lg"
      >
        Get Started on GitHub
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  [data-reveal] {
    opacity: 0.25;
    transform: translateY(0.5rem);
  }
  [data-reveal]:first-child {
    opacity: 1;
    transform: translateY(0);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  const groups = document.querySelectorAll('[data-reveal-group]');
  const groupObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const group = entry.target;
          const cards = group.querySelectorAll('[data-reveal]');

          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('is-visible');
            }, i * 500);
          });

          groupObserver.unobserve(group);
        }
      });
    },
    { threshold: 0.15 }
  );

  groups.forEach((group) => {
    groupObserver.observe(group);
  });
</script>
